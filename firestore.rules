rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the document belongs to the logged-in user
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to check admin status
    // (Assuming you set custom claims or store superadmin in a top-level collection)
    function isSuperAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── USERS ──
    // Users can read/write their own profiles. SuperAdmins can manage all.
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isSuperAdmin();
    }

    // ── AGENTS ──
    // Isolated per user. Only the owner can see, edit, or delete their agents.
    match /agents/{agentId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isOwner(resource.data.userId) || isSuperAdmin();
    }
    
    // ── PROMPT VERSIONS & FOLLOW UPS ──
    match /promptVersions/{docId} {
      allow read, write: if isAuthenticated(); // Inherits security mostly from the API server
    }
    match /followUps/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ── CALLS (Transcripts & Recordings) ──
    // Highest security. Only the caller's owner can see the history.
    match /calls/{callId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isOwner(resource.data.userId) || isSuperAdmin();
    }

    // ── CAMPAIGNS (Dialer) ──
    match /campaigns/{campaignId} {
       allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
       allow read, update, delete: if isOwner(resource.data.userId) || isSuperAdmin();
    }

    // ── SETTINGS, API KEYS, WEBHOOKS ──
    match /apiKeys/{keyId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isOwner(resource.data.userId) || isSuperAdmin();
    }
    match /webhooks/{webhookId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isOwner(resource.data.userId) || isSuperAdmin();
    }

    // ── SYSTEM CONFIGURATIONS (Phone numbers, telecom) ──
    match /phoneNumbers/{numberId} {
       allow read: if isAuthenticated();
       allow write: if isSuperAdmin(); 
    }
    match /dncList/{dncId} {
       allow read: if isAuthenticated();
       allow write: if isSuperAdmin();
    }

    // Explicitly reject all other unauthorized access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
