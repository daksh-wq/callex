rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All Firestore access is performed by the Firebase Admin SDK
    // from the Node.js backend and Python AI service.
    // The Admin SDK bypasses security rules entirely.
    // Client-side access is not used in this architecture.
    //
    // This rule allows full read/write access as a safety net
    // to prevent service disruptions. Access control is enforced
    // at the API layer (API key auth, userId scoping, superadmin checks).
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
